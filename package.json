{
  "name": "bossnyumba",
  "version": "1.0.0",
  "description": "BOSSNYUMBA Property Management SaaS Platform",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:demo": "playwright test --config=e2e/playwright.config.ts e2e/tests/live-demo.spec.ts",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "test:e2e:report": "playwright show-report e2e-report",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "eval": "pnpm --filter @bossnyumba/ai-copilot eval",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "uat:walkthrough": "bash scripts/uat-walkthrough.sh",
    "openapi:export": "pnpm -F @bossnyumba/api-gateway openapi:export",
    "audit:fix": "pnpm audit --audit-level=high"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.2",
    "@types/node": "^20.11.0",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.5.6",
      "handlebars": ">=4.7.9",
      "protobufjs": ">=7.5.5",
      "tar": ">=7.5.11",
      "nodemailer": ">=7.0.11",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=5.0.0 <5.1.8": ">=5.1.8",
      "minimatch@>=7.0.0 <7.4.8": ">=7.4.8",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "rollup": ">=4.59.0",
      "storybook": ">=8.6.17",
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10",
      "flatted": ">=3.4.2",
      "drizzle-orm": "0.36.4",
      "@types/react": "18.3.28",
      "@types/react-dom": "18.3.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "@types/react",
        "react"
      ]
    }
  }
}