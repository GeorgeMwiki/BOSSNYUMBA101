# Estate Manager App Environment Variables

# API URL (required in production)
NEXT_PUBLIC_API_URL=https://api.bossnyumba.com/api/v1

# Tenant ID (resolved from auth in production)
NEXT_PUBLIC_TENANT_ID=

# Support contact (no hardcoded fallbacks)
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_SUPPORT_WHATSAPP=
