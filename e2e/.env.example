# =============================================================================
# E2E / Live Demo — Playwright target URLs
# =============================================================================
# Copy to e2e/.env and set for full live demo tests (no hardcoded URLs).
# For local dev, omit and Playwright will use default localhost URLs.
# For CI or production demo, set all below (or source from root .env).
#
# Optional: use dotenv in playwright.config or export before running:
#   export $(grep -v '^#' e2e/.env | xargs) && pnpm run test:e2e
# =============================================================================

BASE_URL=
CUSTOMER_APP_URL=
OWNER_PORTAL_URL=
ADMIN_PORTAL_URL=
ESTATE_MANAGER_URL=
NEXT_PUBLIC_API_URL=
