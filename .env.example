# =============================================================================
# BOSSNYUMBA Environment Configuration — Complete Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Status legend:
#   [REQUIRED]  — App will not start without this
#   [IMPORTANT] — Core feature disabled without this
#   [OPTIONAL]  — Graceful fallback exists
# =============================================================================

# -----------------------------------------------------------------------------
# A. Supabase — PostgreSQL + Auth + Realtime + Storage  [REQUIRED]
# Get keys from: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Supabase JWT signing secret — used by the Brain/payments-ledger to
# verify caller-provided Supabase-issued access tokens server-side.
# Copy from: Dashboard > Settings > API > JWT Secret.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# API-gateway JWT signing secret. Required in production. Must be >= 32 chars.
# Generate with: openssl rand -base64 48
JWT_SECRET=

# CORS allowlist for the API gateway — comma-separated https:// origins.
# Required in production. Leave blank in dev to fall back to localhost.
ALLOWED_ORIGINS=

# Bootstrap secret for initial admin setup (one-time use)
# POST /api/admin/bootstrap with header: x-bootstrap-secret
BOOTSTRAP_SECRET=your-bootstrap-secret-here

# Internal-only endpoints (e.g. tenant-context lookup) require this key
# via X-Internal-Key header. Generate: openssl rand -hex 32
INTERNAL_API_KEY=

# JWT audience/issuer claims for RS256-signed tokens (payments-ledger,
# service-to-service calls). JWT_ACCESS_SECRET is the RS256 private key.
JWT_ACCESS_SECRET=
JWT_AUDIENCE=bossnyumba
JWT_ISSUER=bossnyumba-api

# pino log level: trace|debug|info|warn|error|fatal. Defaults to 'info'.
LOG_LEVEL=info

# Outbox drainer — ticks every OUTBOX_INTERVAL_MS milliseconds, publishing
# up to OUTBOX_BATCH_SIZE events per batch to the in-process bus. Set
# OUTBOX_WORKER_DISABLED=true only in environments where a dedicated
# out-of-process worker takes over drainage.
OUTBOX_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=50
OUTBOX_WORKER_DISABLED=

# Notifications service base URL (used by domain event subscribers to
# dispatch customer-visible notifications). When unset, subscribers log
# what they WOULD have sent but do not fail. Set in production.
NOTIFICATIONS_SERVICE_URL=

# Transactional outbound mail must come from an owned domain. All
# notification providers refuse to send without this (or per-tenant
# override registered at runtime).
NOTIFICATIONS_FROM_EMAIL=
NOTIFICATIONS_FROM_NAME=BOSSNYUMBA

# Upstream tenant-resolution service used by api-gateway middleware
# when the token lacks tenantId claim. Leave blank in dev.
TENANT_SERVICE_URL=

# Public base URL served by the storage service for signed-download
# redirects. Example: https://storage.bossnyumba.io
STORAGE_BASE_URL=

# Rate limit tuning (applied to api-gateway routes). Defaults:
# REQUESTS_PER_WINDOW=100, WINDOW_MS=60000.
RATE_LIMIT_REQUESTS=
RATE_LIMIT_WINDOW_MS=

# -----------------------------------------------------------------------------
# B. AI Providers — 3-Tier Cascade: Claude → OpenAI → DeepSeek
# Priority: Anthropic (analysis) > OpenAI (conversation/voice) > DeepSeek (batch)
# -----------------------------------------------------------------------------
AI_PROVIDER=anthropic

# Anthropic Claude — Primary AI  [IMPORTANT]
# Get key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6-20260217
CLAUDE_MODEL_PREMIUM=claude-opus-4-6-20260210
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_BASE_URL=                          # optional endpoint override

# OpenAI — First Fallback + Voice/Vision/DALL-E  [IMPORTANT]
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL_DEFAULT=gpt-5.2
OPENAI_VOICE_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_BASE_URL=                             # optional endpoint override
OPENAI_REALTIME_URL=                         # optional WebSocket URL

# DeepSeek — Second Fallback (Cost-Effective Batch)  [OPTIONAL]
# Get key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL_DEFAULT=deepseek-chat
DEEPSEEK_BASE_URL=                           # optional endpoint override

# -----------------------------------------------------------------------------
# C. ElevenLabs — Voice AI (STT + TTS + Conversational AI)  [IMPORTANT]
# Get key from: https://elevenlabs.io/app/settings/api-keys
# Agent ID from: https://elevenlabs.io/app/conversational-ai
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_MODEL_STT=scribe_v2
ELEVENLABS_MODEL_TTS=eleven_flash_v2_5
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_API_ENDPOINT=                     # optional override

# -----------------------------------------------------------------------------
# D. Neo4j — Knowledge Graph  [OPTIONAL]
# Falls back to demo mode when not configured
# Get free instance: https://neo4j.com/cloud/aura-free/
# -----------------------------------------------------------------------------
# Source reads NEO4J_URI + NEO4J_USER. An earlier NEO4J_USERNAME entry
# was ignored by the code and left pre-Wave-25 deployments authing with
# the driver default. Keep BOTH keys below in your secrets — tooling
# that still reads the old names will also see a value.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=neo4j
NEO4J_MAX_POOL_SIZE=50
NEO4J_ACQUISITION_TIMEOUT=60000
NEO4J_CONNECTION_TIMEOUT=30000
NEO4J_MAX_RETRY_TIME=30000

# -----------------------------------------------------------------------------
# E. Stripe — Subscription Billing  [IMPORTANT for billing]
# Get keys from: https://dashboard.stripe.com/apikeys
# Webhook secret from: https://dashboard.stripe.com/webhooks
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Currency conversion (TZS per 1 USD, default: 2500)
TZS_USD_EXCHANGE_RATE=2500

# -----------------------------------------------------------------------------
# F. Mobile Money — Tanzania Payments (M-Pesa, TigoPesa, etc.)  [OPTIONAL]
# Callback URL receives async payment confirmations from providers
# -----------------------------------------------------------------------------
MOBILE_MONEY_ENV=sandbox
MOBILE_MONEY_CALLBACK_URL=https://your-domain/api/webhooks/mobile-money

# M-Pesa (Vodacom Tanzania) — https://openapiportal.m-pesa.com
MPESA_API_KEY=
MPESA_API_SECRET=
MPESA_BUSINESS_SHORT_CODE=
MPESA_CALLBACK_URL=
# IP allowlist for /webhooks/mpesa/* — comma-separated. Defaults to
# Safaricom's 14 production source IPs when unset. Set this to your
# sandbox proxy IP during development, or enable MPESA_DISABLE_IP_ALLOWLIST
# for local ngrok-based testing.
MPESA_ALLOWED_IPS=
MPESA_DISABLE_IP_ALLOWLIST=                  # "true" to bypass allowlist in dev only
MPESA_CONSUMER_KEY=                          # Daraja consumer key
MPESA_CONSUMER_SECRET=                       # Daraja consumer secret
MPESA_SHORT_CODE=                            # Paybill / Till number
MPESA_PASS_KEY=                              # Daraja pass key (STK Push)
MPESA_ENVIRONMENT=sandbox                    # sandbox | production
MPESA_INITIATOR_PASSWORD=                    # B2C initiator password (plaintext; we RSA-encrypt per request)
# Safaricom's public cert (PEM) — used to RSA-encrypt the initiator
# password into the SecurityCredential Daraja requires for B2C. Download
# from https://developer.safaricom.co.ke/ (different cert per env).
# Either inline the PEM in the env var or point to a file via MPESA_CERT_PATH.
MPESA_SANDBOX_CERT=
MPESA_PRODUCTION_CERT=
MPESA_CERT_PATH=

# Tigo Pesa — Tigo Pesa Business API
TIGOPESA_API_KEY=
TIGOPESA_API_SECRET=
TIGOPESA_BUSINESS_SHORT_CODE=
TIGOPESA_CALLBACK_SECRET=                    # For callback signature verification

# Airtel Money — https://developers.airtel.africa
AIRTELMONEY_API_KEY=
AIRTELMONEY_API_SECRET=
AIRTELMONEY_BUSINESS_SHORT_CODE=
AIRTEL_WEBHOOK_SECRET=                       # HMAC-SHA256 webhook signature

# Halopesa (Halotel)
HALOPESA_API_KEY=
HALOPESA_API_SECRET=
HALOPESA_BUSINESS_SHORT_CODE=
HALOPESA_WEBHOOK_USER=                       # Basic Auth webhook credentials
HALOPESA_WEBHOOK_PASSWORD=

# Cron secret for scheduled jobs (payment expiration, etc.)
CRON_SECRET=

# -----------------------------------------------------------------------------
# G. Twilio — SMS, WhatsApp, Voice, 2FA  [IMPORTANT]
# Get keys from: https://console.twilio.com
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886
TWILIO_SMS_NUMBER=                           # optional

# -----------------------------------------------------------------------------
# H. Redis — Caching, Rate Limiting, Queues (BullMQ)
# REDIS_URL: TCP URL for BullMQ (notifications, reports). Required in production.
# Upstash REST: optional for serverless rate limiting.
# Get free instance: https://console.upstash.com or use Redis Cloud
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=                                # optional; use REDIS_URL preferred
REDIS_PORT=6379
REDIS_PASSWORD=
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# -----------------------------------------------------------------------------
# I. Resend — Transactional Email  [OPTIONAL]
# Get key from: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@bossnyumba.com
RESEND_API_URL=                              # optional override

# -----------------------------------------------------------------------------
# J. Tanzanian Regulatory APIs  [OPTIONAL — needed for production KYC]
# These require formal agreements with Tanzanian authorities
# -----------------------------------------------------------------------------

# NIDA — National ID Verification (KYC)
NIDA_API_URL=
NIDA_API_KEY=
NIDA_CLIENT_ID=
NIDA_CLIENT_SECRET=
NIDA_CERTIFICATE=
NIDA_ENVIRONMENT=sandbox

# CRB — Credit Reference Bureau
CRB_API_URL=
CRB_API_KEY=
CRB_SUBSCRIBER_ID=
CRB_SUBSCRIBER_PASSWORD=
CRB_ENVIRONMENT=sandbox

# BRELA — Business Registration Verification
BRELA_API_URL=
BRELA_API_KEY=

# TRA — Tanzania Revenue Authority (Tax Verification)
TRA_API_URL=
TRA_API_KEY=

# -----------------------------------------------------------------------------
# K. Hume AI — Voice Emotion & Biomarker Detection  [OPTIONAL]
# Get key from: https://beta.hume.ai
# -----------------------------------------------------------------------------
HUME_AI_API_KEY=

# -----------------------------------------------------------------------------
# L. Azure Services  [OPTIONAL]
# Alternative providers for speech and translation
# -----------------------------------------------------------------------------
AZURE_SPEECH_KEY=                            # optional STT alternative
AZURE_TRANSLATOR_KEY=                        # optional translation
AZURE_TRANSLATOR_REGION=eastus

# -----------------------------------------------------------------------------
# M. Google Services  [OPTIONAL]
# Translation, video generation, web search
# -----------------------------------------------------------------------------
GOOGLE_TRANSLATE_API_KEY=                    # optional translation
GOOGLE_VEO_API_KEY=                          # video generation
GOOGLE_VEO_BASE_URL=                         # optional override
SEARCH_API_KEY=                              # custom search API
SEARCH_ENGINE_ID=                            # custom search engine ID

# -----------------------------------------------------------------------------
# N. Intron — Swahili TTS  [OPTIONAL]
# Fallback for Swahili voice when ElevenLabs unavailable
# -----------------------------------------------------------------------------
INTRON_API_KEY=
INTRON_API_ENDPOINT=https://api.intron.io/v1

# -----------------------------------------------------------------------------
# O. Enterprise Connectors  [OPTIONAL — per partner configuration]
# -----------------------------------------------------------------------------

# Temenos T24/Transact (Core Banking)
TEMENOS_API_URL=
TEMENOS_API_KEY=
TEMENOS_CLIENT_ID=
TEMENOS_CLIENT_SECRET=
TEMENOS_ENVIRONMENT=sandbox
TEMENOS_RATE_LIMIT=60

# Mambu (Cloud Core Banking)
MAMBU_API_URL=
MAMBU_API_KEY=
MAMBU_ENVIRONMENT=sandbox
MAMBU_RATE_LIMIT=120
MAMBU_WEBHOOK_SECRET=

# CNO (Core Banking)
CNO_API_URL=
CNO_API_KEY=
CNO_ENVIRONMENT=sandbox
CNO_RATE_LIMIT=30

# Avoka / Temenos Journey Manager (Digital Banking)
AVOKA_API_URL=
AVOKA_CLIENT_ID=
AVOKA_CLIENT_SECRET=
AVOKA_ENVIRONMENT=sandbox
AVOKA_RATE_LIMIT=60

# Kony / HCL Volt MX (Mobile Banking)
KONY_API_URL=
KONY_API_KEY=
KONY_APP_KEY=
KONY_APP_SECRET=
KONY_ENVIRONMENT=sandbox
KONY_RATE_LIMIT=100

# Salesforce CRM
SALESFORCE_INSTANCE_URL=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_ENVIRONMENT=sandbox
SALESFORCE_RATE_LIMIT=100
SALESFORCE_API_VERSION=v59.0

# Gmail API (Deep Email Integration)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
GMAIL_RATE_LIMIT=250

# Connector Infrastructure
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT_MS=30000
CB_HALF_OPEN_REQUESTS=3
CONNECTOR_HEALTH_CHECK_INTERVAL_MS=300000
CONNECTOR_MAX_RETRIES=3
CONNECTOR_RETRY_BASE_MS=1000

# -----------------------------------------------------------------------------
# P. Security — Field-Level Encryption & Key Rotation  [IMPORTANT for PII]
# Generate keys with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
ENCRYPTION_MASTER_KEY=
ENCRYPTION_MASTER_KEY_PREVIOUS=
ENCRYPTION_KEY_VERSION=1
SECURITY_ALERT_EMAIL=security@bossnyumba.com
CLOUDFLARE_API_TOKEN=

# -----------------------------------------------------------------------------
# Q. Application Settings (no hardcoded URLs in production)
# -----------------------------------------------------------------------------
# Production: set API_URL and FRONTEND_URL (required). Per-app URLs below.
API_URL=
FRONTEND_URL=
NEXT_PUBLIC_APP_URL=
NODE_ENV=development

# Support & emergency (customer-facing; no hardcoded fallbacks in production)
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_SUPPORT_WHATSAPP=
NEXT_PUBLIC_SUPPORT_EMAIL=
# Optional: emergency contact labels/phones (comma-separated "name|phone|hours" per line or use defaults)
NEXT_PUBLIC_EMERGENCY_PRIMARY_PHONE=
NEXT_PUBLIC_EMERGENCY_MAINTENANCE_PHONE=
NEXT_PUBLIC_EMERGENCY_SECURITY_PHONE=

# Feature flags
NEXT_PUBLIC_USE_AI_APPRAISAL=true
NEXT_PUBLIC_USE_AI_DESKTOP_REVIEW=true

# Build metadata (auto-populated in CI)
NEXT_PUBLIC_GIT_BRANCH=
NEXT_PUBLIC_GIT_COMMIT=

# Staff access control (API gateway platform admin role mapping)
STAFF_ADMIN_EMAILS=
STAFF_SUPPORT_EMAILS=
NEXT_PUBLIC_STAFF_ALLOWED_DOMAINS=
STAFF_ALLOWED_DOMAINS=

# Seed (production: set SEED_ADMIN_EMAIL, SEED_ADMIN_PASSWORD)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
# Platform admin (api-gateway; comma-separated emails; one shared password in production)
PLATFORM_ADMIN_EMAILS=
PLATFORM_ADMIN_PASSWORD=
# Admin portal demo (optional)
VITE_DEMO_ADMIN_EMAIL=
VITE_DEMO_ADMIN_PASSWORD=
VITE_DEMO_SUPPORT_EMAIL=
VITE_DEMO_SUPPORT_PASSWORD=

# -----------------------------------------------------------------------------
# Q2. E2E / Live Demo — Playwright target URLs (no hardcoded defaults in CI)
# Set when running: pnpm run test:e2e (or e2e script) against deployed apps.
# -----------------------------------------------------------------------------
BASE_URL=
CUSTOMER_APP_URL=
OWNER_PORTAL_URL=
ADMIN_PORTAL_URL=
ESTATE_MANAGER_URL=
# Optional: API base for backend assertions
NEXT_PUBLIC_API_URL=

# -----------------------------------------------------------------------------
# R. MCP (Model Context Protocol) Integration
# -----------------------------------------------------------------------------
MCP_API_KEY=your-mcp-api-key-here
MCP_API_KEYS=
MCP_ENABLED=true
MCP_RATE_LIMIT=30
MCP_DEFAULT_TIER=standard
MCP_MONTHLY_BUDGET_USD=500
MCP_HEALTH_CHECK_INTERVAL_S=300

# -----------------------------------------------------------------------------
# S. Knowledge Intelligence Layer  [OPTIONAL]
# -----------------------------------------------------------------------------
GOOGLE_KG_API_KEY=
KNOWLEDGE_FETCH_ENABLED=true
KNOWLEDGE_AUTO_INGEST=true
KNOWLEDGE_MIN_RELEVANCE=0.6
KNOWLEDGE_MONTHLY_BUDGET=50

# -----------------------------------------------------------------------------
# T. E2E / Live Demo Tests  [REQUIRED for test:e2e and live demo]
# Set app URLs and optional demo credentials (no hardcoded credentials in prod)
# -----------------------------------------------------------------------------
BASE_URL=
OWNER_PORTAL_URL=
ADMIN_PORTAL_URL=
CUSTOMER_APP_URL=
ESTATE_MANAGER_URL=
# Demo test accounts (optional; when set, E2E uses these instead of fixtures)
E2E_TEST_OWNER_EMAIL=
E2E_TEST_OWNER_PASSWORD=
E2E_TEST_ADMIN_EMAIL=
E2E_TEST_ADMIN_PASSWORD=
E2E_TEST_MANAGER_EMAIL=
E2E_TEST_MANAGER_PASSWORD=
E2E_TEST_CUSTOMER_PHONE=
E2E_TEST_OTP_CODE=

# -----------------------------------------------------------------------------
# U. OCR Providers — Document Intelligence service  [IMPORTANT]
# Controls which OCR backend the document-intelligence service dispatches to.
# Switching providers is an env-only change — no redeploy needed when the
# provider factory is used correctly.
# -----------------------------------------------------------------------------
# OCR_PROVIDER: which backend to hit. textract|google|mock
#   - textract  uses AWS Textract (requires AWS_* below)
#   - google    uses Google Cloud Vision (requires GOOGLE_APPLICATION_CREDENTIALS)
#   - mock      deterministic in-memory stub — dev & unit tests
OCR_PROVIDER=mock

# AWS Textract — needs an IAM principal scoped to textract:* + s3:GetObject on
# the intake bucket. Do NOT reuse the platform master AWS creds here.
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google Cloud Vision — path to a service-account JSON file reachable inside
# the document-intelligence container (mount via docker-compose.override.yml
# or the ECS task definition's mountPoints in production).
GOOGLE_APPLICATION_CREDENTIALS=

# -----------------------------------------------------------------------------
# V. GePG — Tanzania Government electronic Payment Gateway  [IMPORTANT]
# The payments service issues control numbers and webhooks service verifies
# incoming HMAC-signed reconciliation callbacks.
# GEPG_MODE switches between sandbox (integration) and production endpoints.
# -----------------------------------------------------------------------------
GEPG_SP_CODE=
GEPG_SIGNING_KEY=
GEPG_BASE_URL=https://sandbox.gepg.go.tz
GEPG_MODE=sandbox

# -----------------------------------------------------------------------------
# W. Platform service URLs (internal compose / ECS DNS names)  [REQUIRED]
# api-gateway and domain-services dispatch to these over the private network.
# Leave unset in local dev — defaults to compose service names inside the
# `bossnyumba-network` bridge.
# -----------------------------------------------------------------------------
# NOTIFICATIONS_SERVICE_URL is declared in section A — re-exported here for
# discoverability when wiring a new service. DATABASE_URL / REDIS_URL live
# above; keep this block empty unless you need to pin non-default hosts.
# NEO4J_URL is an operator-convenience alias only — source code reads
# NEO4J_URI (see section D). Keep both set if legacy tooling depends on
# the old name.
DATABASE_URL=postgresql://bossnyumba:bossnyumba_dev@localhost:5432/bossnyumba
NEO4J_URL=bolt://localhost:7687

# -----------------------------------------------------------------------------
# X. Observability — Sentry + PostHog  [IMPORTANT in prod]
# api-gateway (server-side) and Next.js apps (NEXT_PUBLIC_*) both emit
# -----------------------------------------------------------------------------
SENTRY_DSN=                                   # server-side Sentry DSN
SENTRY_ENVIRONMENT=                           # defaults to NODE_ENV when unset
SENTRY_TRACES_SAMPLE_RATE=0.1                 # 0.0-1.0 (float)
POSTHOG_API_KEY=                              # server-side project key
POSTHOG_HOST=https://eu.posthog.com           # EU or US ingest host
NEXT_PUBLIC_SENTRY_DSN=                       # browser-side DSN (public)
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
# Build metadata injected by CI (git rev-parse HEAD). Used as Sentry release.
GIT_SHA=
NEXT_PUBLIC_GIT_SHA=
APP_VERSION=                                  # semver; falls back to 'dev'
DEEP_HEALTH_CACHE_MS=15000                    # /readyz cache TTL

# -----------------------------------------------------------------------------
# Y. Signing secrets for credit certs + agent certs  [REQUIRED in prod]
# -----------------------------------------------------------------------------
# Signs the tenant credit-rating PDF certificate (HMAC). Min 16 chars;
# longer is better. If both are set, CREDIT_CERT_SECRET wins.
CREDIT_CERT_SECRET=
CREDIT_RATING_SIGNING_SECRET=
# Signs agent certification artefacts. Falls back to JWT_SECRET.
# Production refuses to boot if neither is set and >= 32 chars.
AGENT_CERT_SIGNING_SECRET=
# Base URL returned inside signed certs so verifiers can hit our /verify endpoint.
# Prod: set to your public API origin (https://api.bossnyumba.com).
PUBLIC_API_BASE_URL=
API_BASE_URL=
# Agent-card / MCP canonical base URL (served in the a2a agent-card manifest).
PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Z. GePG deep config (signature + keys) — extends section V
# -----------------------------------------------------------------------------
GEPG_SP=
GEPG_SP_SYS_ID=
GEPG_ENV=sandbox                              # sandbox | production
GEPG_PSP_MODE=true                            # 'false' switches to direct RSA mode
GEPG_HMAC_SECRET=                             # HMAC-PSP mode callback verification
GEPG_PUBLIC_CERT_PEM=                         # RSA-gepg mode: GePG signing public cert (PEM inline)
GEPG_PKCS12_PATH=                             # path to SP PKCS#12 bundle (TLS + XML-DSig)
GEPG_PKCS12_PASSWORD=
GEPG_CALLBACK_BASE_URL=                       # REQUIRED in prod; where GePG POSTs callbacks
GEPG_HEALTH_URL=                              # optional URL the /readyz probe hits
# Direct-mode file-based keys (alt to inline PEMs)
GEPG_SIGNING_KEY_PEM=
GEPG_SIGNING_CERT_PEM=
GEPG_SIGNING_KEY_PATH=
GEPG_SIGNING_CERT_PATH=

# -----------------------------------------------------------------------------
# AA. Tenant context + dev defaults  [OPTIONAL — dev only]
# -----------------------------------------------------------------------------
DEFAULT_TENANT_COUNTRY=TZ                     # ISO-3166 alpha-2; REQUIRED in prod if new-tenant bootstrap is used
DEFAULT_TENANT_CURRENCY=TZS                   # ISO-4217; REQUIRED in prod if new-tenant bootstrap is used
DEFAULT_TENANT_CITY=Dar es Salaam
DEV_DEFAULT_COUNTRY_CODE=                     # fallback country for dev-only requests without tenant claim

# -----------------------------------------------------------------------------
# BB. Reports / workers / outbox tuning  [OPTIONAL]
# -----------------------------------------------------------------------------
REPORTS_WORKER_CONCURRENCY=4                  # BullMQ report worker concurrency (default 4)
RATE_LIMIT_MAX_REQUESTS=100                   # per-IP ceiling per window
# OUTBOX_* + OUTBOX_WORKER_DISABLED already in section A.
BOSSNYUMBA_BG_TASKS_ENABLED=                  # 'false' disables all background tasks (dev convenience)
BOSSNYUMBA_SKIP_DOTENV=                       # 'true' skips reading .env at api-gateway boot (container env only)
BOSSNYUMBA_ALLOW_TEARDOWN=                    # 'true' required by scripts/teardown-tenant.ts
SEED_ORG_SEEDS=                               # 'true' includes org-specific seeds in dev run-seed
SEED_DEMO=                                    # 'true' runs the demo seed pack
SEED_TENANT_PHONE=
SEED_PROPERTY_CITY=Nairobi

# -----------------------------------------------------------------------------
# CC. WhatsApp Business Cloud API (Meta)  [IMPORTANT]
# -----------------------------------------------------------------------------
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=                        # Meta system-user permanent token
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=                # static shared secret for webhook handshake
META_APP_SECRET=                              # used to HMAC-verify inbound Meta webhooks
AFRICASTALKING_WEBHOOK_SECRET=                # HMAC verification for AT delivery reports

# -----------------------------------------------------------------------------
# DD. SMTP fallback email provider  [OPTIONAL]
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false                             # 'true' for port 465
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# EE. Webhook infrastructure  [IMPORTANT]
# -----------------------------------------------------------------------------
# Default HMAC secret used when a tenant webhook subscription has no override.
WEBHOOK_DEFAULT_HMAC_SECRET=
# 'true' lets outbound webhooks target private-IP / localhost URLs — dev only.
WEBHOOK_SSRF_ALLOW_PRIVATE=

# -----------------------------------------------------------------------------
# FF. API key registry + legacy fallback
# -----------------------------------------------------------------------------
# Comma-separated entries: "sha256hex:tenantId:role:space-delimited-scopes:serviceName"
# Generate hashes via: echo -n "$KEY" | openssl dgst -sha256 -hex | awk '{print $2}'
API_KEY_REGISTRY=
# DEPRECATED — legacy exact-match comma list. Production boots OK if only
# this is set but emits a CRITICAL warning. Migrate to API_KEY_REGISTRY.
API_KEYS=
# X-Internal-Key header for internal service-to-service calls (tenant-context
# resolution, notifications dispatch). Generate: openssl rand -hex 32.
# Already declared in section A — re-mentioned here for discoverability.

# -----------------------------------------------------------------------------
# GG. JWT claim tuning  [OPTIONAL — defaults are sensible]
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=                            # alt to JWT_SECRET (RS256 private key)
JWT_EXPIRES_IN=                               # e.g. "15m"; consumed by @bossnyumba/config
JWT_AUDIENCE=bossnyumba-api
JWT_ISSUER=bossnyumba

# -----------------------------------------------------------------------------
# HH. Vite dev proxy target  [dev only]
# -----------------------------------------------------------------------------
VITE_API_PROXY_TARGET=http://localhost:4000

# -----------------------------------------------------------------------------
# II. E2E + test-mode toggles
# -----------------------------------------------------------------------------
USE_MOCK_DATA=false                           # 'true' forces api-gateway to return fixture data
USE_REAL_SERVERS=                             # e2e: 'true' skips Playwright's webServer auto-start
E2E_REAL_LLM=                                 # 'true' runs the real-LLM e2e suite (requires keys)
E2E_GATEWAY_URL=http://localhost:4000
E2E_TEST_JWT=                                 # pre-minted JWT for e2e requests
KEEP_TEST_DB=                                 # '1' keeps the test DB after integration runs
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=bossnyumba_test
TEST_DB_USER=postgres
TEST_DB_PASSWORD=

# -----------------------------------------------------------------------------
# JJ. Load testing (services/api-gateway/scripts/load-test.ts)
# -----------------------------------------------------------------------------
LOAD_TEST_PORT=4001
LOAD_TEST_CONNECTIONS=10
LOAD_TEST_DURATION=30
LOAD_TEST_JWT_SECRET=

# -----------------------------------------------------------------------------
# KK. Payments-ledger tuning
# -----------------------------------------------------------------------------
PLATFORM_FEE_PERCENT=5.0                      # percent of each disbursement taken as platform fee
STRIPE_CONNECTED_ACCOUNT_ID=                  # Stripe Connect platform account
TANZANIA_PAYMENT_BACKEND=                     # 'mpesa' | 'tigopesa' | 'airtel' | 'halopesa' | unset (factory picks)

# -----------------------------------------------------------------------------
# LL. Africa's Talking legacy aliases (prefer AFRICAS_TALKING_*)
# -----------------------------------------------------------------------------
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
AT_ENVIRONMENT=sandbox

# -----------------------------------------------------------------------------
# MM. Twilio auth-token alias (used by notification webhook verifier)
# -----------------------------------------------------------------------------
# TWILIO_AUTH_TOKEN already in section G — used for Twilio webhook verification.

# -----------------------------------------------------------------------------
# NN. AWS Textract region (OCR)
# -----------------------------------------------------------------------------
AWS_TEXTRACT_REGION=eu-west-1                 # used by services/api-gateway/src/routes/scans.router.ts

# -----------------------------------------------------------------------------
# OO. Operator / migration tooling
# -----------------------------------------------------------------------------
OPERATOR_ENV=                                 # override NODE_ENV for scripts/migrate-prod.ts

# -----------------------------------------------------------------------------
# PP. Nano-banana imagery renderer + Typst PDF engine
# -----------------------------------------------------------------------------
NANO_BANANA_API_URL=
NANO_BANANA_API_KEY=
TYPST_BIN=typst                               # path to Typst binary (defaults to PATH lookup)

# -----------------------------------------------------------------------------
# QQ. Storage service public URL  (already in section A — re-listed for clarity)
# -----------------------------------------------------------------------------
# STORAGE_BASE_URL declared above.

