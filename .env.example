# =============================================================================
# BOSSNYUMBA Environment Configuration — Complete Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Status legend:
#   [REQUIRED]  — App will not start without this
#   [IMPORTANT] — Core feature disabled without this
#   [OPTIONAL]  — Graceful fallback exists
# =============================================================================

# -----------------------------------------------------------------------------
# A. Supabase — PostgreSQL + Auth + Realtime + Storage  [REQUIRED]
# Get keys from: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Bootstrap secret for initial admin setup (one-time use)
# POST /api/admin/bootstrap with header: x-bootstrap-secret
BOOTSTRAP_SECRET=your-bootstrap-secret-here

# -----------------------------------------------------------------------------
# B. AI Providers — 3-Tier Cascade: Claude → OpenAI → DeepSeek
# Priority: Anthropic (analysis) > OpenAI (conversation/voice) > DeepSeek (batch)
# -----------------------------------------------------------------------------
AI_PROVIDER=anthropic

# Anthropic Claude — Primary AI  [IMPORTANT]
# Get key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6-20260217
CLAUDE_MODEL_PREMIUM=claude-opus-4-6-20260210
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_BASE_URL=                          # optional endpoint override

# OpenAI — First Fallback + Voice/Vision/DALL-E  [IMPORTANT]
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL_DEFAULT=gpt-5.2
OPENAI_VOICE_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_BASE_URL=                             # optional endpoint override
OPENAI_REALTIME_URL=                         # optional WebSocket URL

# DeepSeek — Second Fallback (Cost-Effective Batch)  [OPTIONAL]
# Get key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL_DEFAULT=deepseek-chat
DEEPSEEK_BASE_URL=                           # optional endpoint override

# -----------------------------------------------------------------------------
# C. ElevenLabs — Voice AI (STT + TTS + Conversational AI)  [IMPORTANT]
# Get key from: https://elevenlabs.io/app/settings/api-keys
# Agent ID from: https://elevenlabs.io/app/conversational-ai
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_MODEL_STT=scribe_v2
ELEVENLABS_MODEL_TTS=eleven_flash_v2_5
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_API_ENDPOINT=                     # optional override

# -----------------------------------------------------------------------------
# D. Neo4j — Knowledge Graph  [OPTIONAL]
# Falls back to demo mode when not configured
# Get free instance: https://neo4j.com/cloud/aura-free/
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=neo4j
NEO4J_MAX_POOL_SIZE=50
NEO4J_ACQUISITION_TIMEOUT=60000
NEO4J_CONNECTION_TIMEOUT=30000
NEO4J_MAX_RETRY_TIME=30000

# -----------------------------------------------------------------------------
# E. Stripe — Subscription Billing  [IMPORTANT for billing]
# Get keys from: https://dashboard.stripe.com/apikeys
# Webhook secret from: https://dashboard.stripe.com/webhooks
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Currency conversion (TZS per 1 USD, default: 2500)
TZS_USD_EXCHANGE_RATE=2500

# -----------------------------------------------------------------------------
# F. Mobile Money — Tanzania Payments (M-Pesa, TigoPesa, etc.)  [OPTIONAL]
# Callback URL receives async payment confirmations from providers
# -----------------------------------------------------------------------------
MOBILE_MONEY_ENV=sandbox
MOBILE_MONEY_CALLBACK_URL=https://your-domain/api/webhooks/mobile-money

# M-Pesa (Vodacom Tanzania) — https://openapiportal.m-pesa.com
MPESA_API_KEY=
MPESA_API_SECRET=
MPESA_BUSINESS_SHORT_CODE=
MPESA_CALLBACK_URL=
MPESA_ALLOWED_IPS=                           # IP whitelist (comma-separated CIDRs)

# Tigo Pesa — Tigo Pesa Business API
TIGOPESA_API_KEY=
TIGOPESA_API_SECRET=
TIGOPESA_BUSINESS_SHORT_CODE=
TIGOPESA_CALLBACK_SECRET=                    # For callback signature verification

# Airtel Money — https://developers.airtel.africa
AIRTELMONEY_API_KEY=
AIRTELMONEY_API_SECRET=
AIRTELMONEY_BUSINESS_SHORT_CODE=
AIRTEL_WEBHOOK_SECRET=                       # HMAC-SHA256 webhook signature

# Halopesa (Halotel)
HALOPESA_API_KEY=
HALOPESA_API_SECRET=
HALOPESA_BUSINESS_SHORT_CODE=
HALOPESA_WEBHOOK_USER=                       # Basic Auth webhook credentials
HALOPESA_WEBHOOK_PASSWORD=

# Cron secret for scheduled jobs (payment expiration, etc.)
CRON_SECRET=

# -----------------------------------------------------------------------------
# G. Twilio — SMS, WhatsApp, Voice, 2FA  [IMPORTANT]
# Get keys from: https://console.twilio.com
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886
TWILIO_SMS_NUMBER=                           # optional

# -----------------------------------------------------------------------------
# H. Redis — Caching, Rate Limiting, Queues (BullMQ)
# REDIS_URL: TCP URL for BullMQ (notifications, reports). Required in production.
# Upstash REST: optional for serverless rate limiting.
# Get free instance: https://console.upstash.com or use Redis Cloud
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=                                # optional; use REDIS_URL preferred
REDIS_PORT=6379
REDIS_PASSWORD=
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# -----------------------------------------------------------------------------
# I. Resend — Transactional Email  [OPTIONAL]
# Get key from: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@bossnyumba.com
RESEND_API_URL=                              # optional override

# -----------------------------------------------------------------------------
# J. Tanzanian Regulatory APIs  [OPTIONAL — needed for production KYC]
# These require formal agreements with Tanzanian authorities
# -----------------------------------------------------------------------------

# NIDA — National ID Verification (KYC)
NIDA_API_URL=
NIDA_API_KEY=
NIDA_CLIENT_ID=
NIDA_CLIENT_SECRET=
NIDA_CERTIFICATE=
NIDA_ENVIRONMENT=sandbox

# CRB — Credit Reference Bureau
CRB_API_URL=
CRB_API_KEY=
CRB_SUBSCRIBER_ID=
CRB_SUBSCRIBER_PASSWORD=
CRB_ENVIRONMENT=sandbox

# BRELA — Business Registration Verification
BRELA_API_URL=
BRELA_API_KEY=

# TRA — Tanzania Revenue Authority (Tax Verification)
TRA_API_URL=
TRA_API_KEY=

# -----------------------------------------------------------------------------
# K. Hume AI — Voice Emotion & Biomarker Detection  [OPTIONAL]
# Get key from: https://beta.hume.ai
# -----------------------------------------------------------------------------
HUME_AI_API_KEY=

# -----------------------------------------------------------------------------
# L. Azure Services  [OPTIONAL]
# Alternative providers for speech and translation
# -----------------------------------------------------------------------------
AZURE_SPEECH_KEY=                            # optional STT alternative
AZURE_TRANSLATOR_KEY=                        # optional translation
AZURE_TRANSLATOR_REGION=eastus

# -----------------------------------------------------------------------------
# M. Google Services  [OPTIONAL]
# Translation, video generation, web search
# -----------------------------------------------------------------------------
GOOGLE_TRANSLATE_API_KEY=                    # optional translation
GOOGLE_VEO_API_KEY=                          # video generation
GOOGLE_VEO_BASE_URL=                         # optional override
SEARCH_API_KEY=                              # custom search API
SEARCH_ENGINE_ID=                            # custom search engine ID

# -----------------------------------------------------------------------------
# N. Intron — Swahili TTS  [OPTIONAL]
# Fallback for Swahili voice when ElevenLabs unavailable
# -----------------------------------------------------------------------------
INTRON_API_KEY=
INTRON_API_ENDPOINT=https://api.intron.io/v1

# -----------------------------------------------------------------------------
# O. Enterprise Connectors  [OPTIONAL — per partner configuration]
# -----------------------------------------------------------------------------

# Temenos T24/Transact (Core Banking)
TEMENOS_API_URL=
TEMENOS_API_KEY=
TEMENOS_CLIENT_ID=
TEMENOS_CLIENT_SECRET=
TEMENOS_ENVIRONMENT=sandbox
TEMENOS_RATE_LIMIT=60

# Mambu (Cloud Core Banking)
MAMBU_API_URL=
MAMBU_API_KEY=
MAMBU_ENVIRONMENT=sandbox
MAMBU_RATE_LIMIT=120
MAMBU_WEBHOOK_SECRET=

# CNO (Core Banking)
CNO_API_URL=
CNO_API_KEY=
CNO_ENVIRONMENT=sandbox
CNO_RATE_LIMIT=30

# Avoka / Temenos Journey Manager (Digital Banking)
AVOKA_API_URL=
AVOKA_CLIENT_ID=
AVOKA_CLIENT_SECRET=
AVOKA_ENVIRONMENT=sandbox
AVOKA_RATE_LIMIT=60

# Kony / HCL Volt MX (Mobile Banking)
KONY_API_URL=
KONY_API_KEY=
KONY_APP_KEY=
KONY_APP_SECRET=
KONY_ENVIRONMENT=sandbox
KONY_RATE_LIMIT=100

# Salesforce CRM
SALESFORCE_INSTANCE_URL=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_ENVIRONMENT=sandbox
SALESFORCE_RATE_LIMIT=100
SALESFORCE_API_VERSION=v59.0

# Gmail API (Deep Email Integration)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
GMAIL_RATE_LIMIT=250

# Connector Infrastructure
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT_MS=30000
CB_HALF_OPEN_REQUESTS=3
CONNECTOR_HEALTH_CHECK_INTERVAL_MS=300000
CONNECTOR_MAX_RETRIES=3
CONNECTOR_RETRY_BASE_MS=1000

# -----------------------------------------------------------------------------
# P. Security — Field-Level Encryption & Key Rotation  [IMPORTANT for PII]
# Generate keys with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
ENCRYPTION_MASTER_KEY=
ENCRYPTION_MASTER_KEY_PREVIOUS=
ENCRYPTION_KEY_VERSION=1
SECURITY_ALERT_EMAIL=security@bossnyumba.com
CLOUDFLARE_API_TOKEN=

# -----------------------------------------------------------------------------
# Q. Application Settings (no hardcoded URLs in production)
# -----------------------------------------------------------------------------
# Production: set API_URL and FRONTEND_URL (required). Per-app URLs below.
API_URL=
FRONTEND_URL=
NEXT_PUBLIC_APP_URL=
NODE_ENV=development

# Support & emergency (customer-facing; no hardcoded fallbacks in production)
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_SUPPORT_WHATSAPP=
NEXT_PUBLIC_SUPPORT_EMAIL=
# Optional: emergency contact labels/phones (comma-separated "name|phone|hours" per line or use defaults)
NEXT_PUBLIC_EMERGENCY_PRIMARY_PHONE=
NEXT_PUBLIC_EMERGENCY_MAINTENANCE_PHONE=
NEXT_PUBLIC_EMERGENCY_SECURITY_PHONE=

# Feature flags
NEXT_PUBLIC_USE_AI_APPRAISAL=true
NEXT_PUBLIC_USE_AI_DESKTOP_REVIEW=true

# Build metadata (auto-populated in CI)
NEXT_PUBLIC_GIT_BRANCH=
NEXT_PUBLIC_GIT_COMMIT=

# Staff access control (API gateway platform admin role mapping)
STAFF_ADMIN_EMAILS=
STAFF_SUPPORT_EMAILS=
NEXT_PUBLIC_STAFF_ALLOWED_DOMAINS=
STAFF_ALLOWED_DOMAINS=

# Seed (production: set SEED_ADMIN_EMAIL, SEED_ADMIN_PASSWORD)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
# Platform admin (api-gateway; comma-separated emails; one shared password in production)
PLATFORM_ADMIN_EMAILS=
PLATFORM_ADMIN_PASSWORD=
# Admin portal demo (optional)
VITE_DEMO_ADMIN_EMAIL=
VITE_DEMO_ADMIN_PASSWORD=
VITE_DEMO_SUPPORT_EMAIL=
VITE_DEMO_SUPPORT_PASSWORD=

# -----------------------------------------------------------------------------
# Q2. E2E / Live Demo — Playwright target URLs (no hardcoded defaults in CI)
# Set when running: pnpm run test:e2e (or e2e script) against deployed apps.
# -----------------------------------------------------------------------------
BASE_URL=
CUSTOMER_APP_URL=
OWNER_PORTAL_URL=
ADMIN_PORTAL_URL=
ESTATE_MANAGER_URL=
# Optional: API base for backend assertions
NEXT_PUBLIC_API_URL=

# -----------------------------------------------------------------------------
# R. MCP (Model Context Protocol) Integration
# -----------------------------------------------------------------------------
MCP_API_KEY=your-mcp-api-key-here
MCP_API_KEYS=
MCP_ENABLED=true
MCP_RATE_LIMIT=30
MCP_DEFAULT_TIER=standard
MCP_MONTHLY_BUDGET_USD=500
MCP_HEALTH_CHECK_INTERVAL_S=300

# -----------------------------------------------------------------------------
# S. Knowledge Intelligence Layer  [OPTIONAL]
# -----------------------------------------------------------------------------
GOOGLE_KG_API_KEY=
KNOWLEDGE_FETCH_ENABLED=true
KNOWLEDGE_AUTO_INGEST=true
KNOWLEDGE_MIN_RELEVANCE=0.6
KNOWLEDGE_MONTHLY_BUDGET=50

# -----------------------------------------------------------------------------
# T. E2E / Live Demo Tests  [REQUIRED for test:e2e and live demo]
# Set app URLs and optional demo credentials (no hardcoded credentials in prod)
# -----------------------------------------------------------------------------
BASE_URL=
OWNER_PORTAL_URL=
ADMIN_PORTAL_URL=
CUSTOMER_APP_URL=
ESTATE_MANAGER_URL=
# Demo test accounts (optional; when set, E2E uses these instead of fixtures)
E2E_TEST_OWNER_EMAIL=
E2E_TEST_OWNER_PASSWORD=
E2E_TEST_ADMIN_EMAIL=
E2E_TEST_ADMIN_PASSWORD=
E2E_TEST_MANAGER_EMAIL=
E2E_TEST_MANAGER_PASSWORD=
E2E_TEST_CUSTOMER_PHONE=
E2E_TEST_OTP_CODE=
