{
  "name": "@bossnyumba/ai-copilot",
  "version": "0.1.0",
  "description": "AI copilots, predictive workflows, and governed automation for BOSSNYUMBA platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./services/migration/parsers/parse-upload": {
      "types": "./src/services/migration/parsers/parse-upload.ts",
      "default": "./dist/services/migration/parsers/parse-upload.js"
    },
    "./providers": {
      "types": "./src/providers/index.ts",
      "default": "./dist/providers/index.js"
    },
    "./agent-certification": {
      "types": "./src/agent-certification/index.ts",
      "default": "./dist/agent-certification/index.js"
    },
    "./classroom": {
      "types": "./src/classroom/index.ts",
      "default": "./dist/classroom/index.js"
    },
    "./voice": {
      "types": "./src/voice/index.ts",
      "default": "./dist/voice/index.js"
    },
    "./heartbeat": {
      "types": "./src/heartbeat/index.ts",
      "default": "./dist/heartbeat/index.js"
    },
    "./ambient-brain": {
      "types": "./src/ambient-brain/index.ts",
      "default": "./dist/ambient-brain/index.js"
    },
    "./background-intelligence": {
      "types": "./src/background-intelligence/index.ts",
      "default": "./dist/background-intelligence/index.js"
    },
    "./training": {
      "types": "./src/training/index.ts",
      "default": "./dist/training/index.js"
    },
    "./autonomy": {
      "types": "./src/autonomy/index.ts",
      "default": "./dist/autonomy/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "eval": "tsx src/eval/run-eval.ts"
  },
  "keywords": [
    "ai",
    "copilot",
    "predictive-analytics",
    "machine-learning",
    "property-management",
    "automation"
  ],
  "author": "BOSSNYUMBA",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "jose": "^5.2.0",
    "openai": "^4.28.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.55.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@bossnyumba/domain-models": "*",
    "@bossnyumba/observability": "*"
  },
  "peerDependenciesMeta": {
    "@bossnyumba/domain-models": {
      "optional": true
    },
    "@bossnyumba/observability": {
      "optional": true
    }
  }
}
