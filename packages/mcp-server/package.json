{
  "name": "@bossnyumba/mcp-server",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Model Context Protocol server that exposes BOSSNYUMBA property-management tools, resources, and prompts to external AI agents (Claude Desktop, GPT, Cursor, partner platforms) over a tenant-scoped, cost-accounted, tier-routed interface.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
