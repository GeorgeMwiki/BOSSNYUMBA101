{
  "name": "@bossnyumba/lpms-connector",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "LPMS (Land and Property Management System) ingestion adapters for legacy estate-system exports. Normalizes CSV, JSON, and XML dumps into the shape consumed by MigrationWriterService.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.6",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
