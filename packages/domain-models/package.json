{
  "name": "@bossnyumba/domain-models",
  "version": "0.1.0",
  "private": true,
  "description": "Core domain models and types for BOSSNYUMBA platform",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tenant": {
      "types": "./dist/tenant/index.d.ts",
      "import": "./dist/tenant/index.mjs",
      "require": "./dist/tenant/index.js"
    },
    "./property": {
      "types": "./dist/property/index.d.ts",
      "import": "./dist/property/index.mjs",
      "require": "./dist/property/index.js"
    },
    "./lease": {
      "types": "./dist/lease/index.d.ts",
      "import": "./dist/lease/index.mjs",
      "require": "./dist/lease/index.js"
    },
    "./payment": {
      "types": "./dist/payment/index.d.ts",
      "import": "./dist/payment/index.mjs",
      "require": "./dist/payment/index.js"
    },
    "./maintenance": {
      "types": "./dist/maintenance/index.d.ts",
      "import": "./dist/maintenance/index.mjs",
      "require": "./dist/maintenance/index.js"
    },
    "./audit/audit-event": {
      "types": "./dist/audit/audit-event.d.ts",
      "import": "./dist/audit/audit-event.mjs",
      "require": "./dist/audit/audit-event.js"
    },
    "./identity/user": {
      "types": "./dist/identity/user.d.ts",
      "import": "./dist/identity/user.mjs",
      "require": "./dist/identity/user.js"
    },
    "./identity/session": {
      "types": "./dist/identity/session.d.ts",
      "import": "./dist/identity/session.mjs",
      "require": "./dist/identity/session.js"
    },
    "./maintenance/work-order": {
      "types": "./dist/maintenance/work-order.d.ts",
      "import": "./dist/maintenance/work-order.mjs",
      "require": "./dist/maintenance/work-order.js"
    },
    "./property/property": {
      "types": "./dist/property/property.d.ts",
      "import": "./dist/property/property.mjs",
      "require": "./dist/property/property.js"
    },
    "./property/unit": {
      "types": "./dist/property/unit.d.ts",
      "import": "./dist/property/unit.mjs",
      "require": "./dist/property/unit.js"
    },
    "./lease/lease": {
      "types": "./dist/lease/lease.d.ts",
      "import": "./dist/lease/lease.mjs",
      "require": "./dist/lease/lease.js"
    },
    "./tenant/tenant": {
      "types": "./dist/tenant/tenant.d.ts",
      "import": "./dist/tenant/tenant.mjs",
      "require": "./dist/tenant/tenant.js"
    },
    "./customer/customer": {
      "types": "./dist/customer/customer.d.ts",
      "import": "./dist/customer/customer.mjs",
      "require": "./dist/customer/customer.js"
    },
    "./common/money": {
      "types": "./dist/common/money.d.ts",
      "import": "./dist/common/money.mjs",
      "require": "./dist/common/money.js"
    },
    "./financial/invoice": {
      "types": "./dist/financial/invoice.d.ts",
      "import": "./dist/financial/invoice.mjs",
      "require": "./dist/financial/invoice.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  }
}