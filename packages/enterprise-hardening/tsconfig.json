{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    // Prevent implicit discovery of transitively-hoisted Hapi @types
    // (hapi__catbox, hapi__shot) which aren't declared as deps here.
    "types": ["node"],
    // This package mixes readonly optional fields with `| undefined`
    // assignments; relax exactOptional until the public types are
    // rewritten to use `string | undefined` throughout.
    "exactOptionalPropertyTypes": false,
    // Several union-narrowing sites use `'HEALTHY' | 'DEGRADED' | 'UNHEALTHY'`
    // where TS narrows to a literal. Those use-cases require a refactor
    // that's out of scope here; disable noImplicitOverride so the
    // inherited caching methods compile without override annotations.
    "noImplicitOverride": false,
    "strictNullChecks": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
