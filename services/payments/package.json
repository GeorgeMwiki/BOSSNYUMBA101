{
  "name": "@bossnyumba/payments-service",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Mobile money payment integrations (M-Pesa, Airtel Money, Tigo Pesa) for BOSSNYUMBA",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers/*": {
      "types": "./dist/providers/*/index.d.ts",
      "default": "./dist/providers/*/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pino": "^8.21.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/uuid": "^9.0.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
