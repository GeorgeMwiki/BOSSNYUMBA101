  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/node": "^25.6.0",
    "@types/pdfkit": "^0.13.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
