{
  "name": "@bossnyumba/api-gateway",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "API Gateway / BFF for BOSSNYUMBA platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "dev:no-env": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:routes": "vitest run src/__tests__",
    "openapi:export": "node scripts/export-openapi.mjs",
    "clean": "rm -rf dist .turbo",
    "load-test": "node scripts/load-test.mjs"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@bossnyumba/agent-platform": "workspace:*",
    "@bossnyumba/ai-copilot": "workspace:*",
    "@bossnyumba/authz-policy": "workspace:*",
    "@bossnyumba/central-intelligence": "workspace:*",
    "@bossnyumba/compliance-plugins": "workspace:*",
    "@bossnyumba/database": "workspace:*",
    "@bossnyumba/domain-models": "workspace:*",
    "@bossnyumba/domain-services": "workspace:*",
    "@bossnyumba/forecasting": "workspace:*",
    "@bossnyumba/graph-sync": "workspace:*",
    "@bossnyumba/lpms-connector": "workspace:*",
    "@bossnyumba/marketing-brain": "workspace:*",
    "@bossnyumba/mcp-server": "workspace:*",
    "@bossnyumba/observability": "workspace:*",
    "@bossnyumba/payments-ledger-service": "workspace:*",
    "@bossnyumba/payments-service": "workspace:*",
    "@bossnyumba/spotlight": "workspace:*",
    "@hono/node-server": "^2.0.0",
    "@hono/zod-openapi": "^1.3.0",
    "@hono/zod-validator": "^0.7.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "hono": "^4.6.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.2",
    "opossum": "^9.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/opossum": "^8.1.9",
    "@types/supertest": "^6.0.3",
    "autocannon": "^8.0.0",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
