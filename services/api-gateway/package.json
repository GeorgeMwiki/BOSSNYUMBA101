{
  "name": "@bossnyumba/api-gateway",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "API Gateway / BFF for BOSSNYUMBA platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:routes": "vitest run src/__tests__",
    "openapi:export": "node scripts/export-openapi.mjs",
    "clean": "rm -rf dist .turbo",
    "load-test": "node scripts/load-test.mjs"
  },
  "dependencies": {
    "@bossnyumba/ai-copilot": "workspace:*",
    "@bossnyumba/authz-policy": "workspace:*",
    "@bossnyumba/database": "workspace:*",
    "@bossnyumba/domain-models": "workspace:*",
    "@bossnyumba/domain-services": "workspace:*",
    "@bossnyumba/graph-sync": "workspace:*",
    "@bossnyumba/lpms-connector": "workspace:*",
    "@bossnyumba/observability": "workspace:*",
    "@bossnyumba/payments-ledger-service": "workspace:*",
    "@bossnyumba/payments-service": "workspace:*",
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@hono/node-server": "^1.11.0",
    "@hono/zod-openapi": "^0.16.4",
    "@hono/zod-validator": "^0.4.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "hono": "^4.6.0",
    "jose": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "opossum": "^8.5.0",
    "pino": "^8.18.0",
    "pino-http": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/opossum": "^8.1.9",
    "@types/supertest": "^6.0.3",
    "autocannon": "^8.0.0",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}