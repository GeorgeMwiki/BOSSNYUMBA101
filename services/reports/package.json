{
  "name": "@bossnyumba/reports-service",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Reports and Analytics service for BOSSNYUMBA - PDF, Excel, CSV generation with scheduled delivery",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:scheduler": "node dist/scheduler/scheduler-runner.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "bullmq": "^5.68.0",
    "exceljs": "^4.4.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.15.2",
    "uuid": "^9.0.0",
    "@bossnyumba/domain-models": "workspace:*",
    "@bossnyumba/compliance-plugins": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.13.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}