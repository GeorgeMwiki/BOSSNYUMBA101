{
  "name": "@bossnyumba/retention-worker",
  "version": "1.0.0",
  "description": "Nightly data retention sweep worker honoring legal holds for BOSSNYUMBA",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "sweep": "node dist/index.js --once",
    "sweep:dry-run": "node dist/index.js --once --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bossnyumba/database": "workspace:*",
    "@bossnyumba/enterprise-hardening": "workspace:*",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
