{
  "name": "@bossnyumba/retention-worker",
  "version": "1.0.0",
  "description": "Background worker that enforces data retention policies (soft/hard delete, legal hold exemption)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bossnyumba/database": "workspace:*",
    "@bossnyumba/enterprise-hardening": "workspace:*",
    "@bossnyumba/queue": "workspace:*",
    "drizzle-orm": "^0.29.3",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
