{
  "name": "@bossnyumba/tax-compliance",
  "version": "1.0.0",
  "description": "Tax compliance service for BOSSNYUMBA: Tanzania Revenue Authority (TRA) VAT + Withholding Tax, and rental income tax calculators",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "pino": "^8.21.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  }
}
