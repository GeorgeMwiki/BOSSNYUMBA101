# =============================================================================
# BOSSNYUMBA - Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env to use with docker-compose:
#   cp .env.docker .env
#
# IMPORTANT: Never commit the .env file to version control.
# All credentials MUST be set via environment variables.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=bossnyumba
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=bossnyumba
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=
REDIS_PORT=6379

# --- Neo4j Graph Database ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_password

# --- API Gateway ---
NODE_ENV=development
API_PORT=4000
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret

# --- Supabase (BOSSNYUMBA's own project - never shared) ---
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# 1. Create a new Supabase project at https://supabase.com
# 2. Go to Settings > API to find these keys
# 3. Run migration: psql $DATABASE_URL < packages/database/src/migrations/0011_user_contexts_and_features.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- URLs (only needed in production; dev uses localhost defaults) ---
# API_URL=https://api.bossnyumba.com
# FRONTEND_URL=https://app.bossnyumba.com

# --- Payments (set when ready to accept payments) ---
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_PASSKEY=
# MPESA_SHORTCODE=
# STRIPE_SECRET_KEY=
# FLUTTERWAVE_SECRET_KEY=

# --- Notifications ---
# AFRICAS_TALKING_API_KEY=
# AFRICAS_TALKING_USERNAME=sandbox
# SENDGRID_API_KEY=
# FIREBASE_PROJECT_ID=

# --- AI Providers ---
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# --- Storage ---
# AWS_ACCESS_KEY_ID=
