{
  "title": "BOSSNYUMBA — Platform Overview",
  "uid": "bossnyumba-overview",
  "tags": ["bossnyumba", "overview"],
  "schemaVersion": 38,
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests/sec",
      "targets": [{ "expr": "sum(rate(http_requests_total[1m])) by (service)" }],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Error rate (5xx)",
      "targets": [{ "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (service)" }],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "P95 latency by service",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket[5m])) by (le, service))" }],
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 }
    }
  ]
}
