# =============================================================================
# Staging - Terraform Variables (EXAMPLE)
# =============================================================================
# Copy to terraform.tfvars (gitignored) and fill in sensitive values.
# Prefer environment variables for secrets:
#   export TF_VAR_rds_password="..."
#   export TF_VAR_rds_username="..."
# DO NOT commit terraform.tfvars.
# =============================================================================

project_name = "bossnyumba"
environment  = "staging"
aws_region   = "eu-west-1"

# -----------------------------------------------------------------------------
# VPC / Networking (staging: 2 AZs, single NAT to save cost)
# -----------------------------------------------------------------------------
vpc_cidr             = "10.10.0.0/16"
availability_zones   = ["eu-west-1a", "eu-west-1b"]
public_subnet_cidrs  = ["10.10.1.0/24", "10.10.2.0/24"]
private_subnet_cidrs = ["10.10.10.0/24", "10.10.11.0/24"]

enable_nat_gateway = true
single_nat_gateway = true

# -----------------------------------------------------------------------------
# RDS (staging: small instance, no Multi-AZ)
# -----------------------------------------------------------------------------
rds_instance_class    = "db.t3.small"
rds_allocated_storage = 20
rds_database_name     = "bossnyumba_staging"
# rds_username = "bossnyumba"   # prefer TF_VAR_rds_username
# rds_password = "CHANGE_ME"    # prefer TF_VAR_rds_password
rds_multi_az = false

# -----------------------------------------------------------------------------
# Redis (staging: single node)
# -----------------------------------------------------------------------------
redis_node_type          = "cache.t3.micro"
redis_num_cache_clusters = 1

# -----------------------------------------------------------------------------
# ECS / API (staging: minimal footprint)
# -----------------------------------------------------------------------------
api_image         = "bossnyumba/api-gateway:staging"
api_cpu           = 256
api_memory        = 512
api_desired_count = 1

enable_container_insights = true

# -----------------------------------------------------------------------------
# App services (staging)
# -----------------------------------------------------------------------------
app_services = {
  estate-manager = {
    image         = "bossnyumba/estate-manager-app:staging"
    cpu           = 256
    memory        = 512
    port          = 3000
    desired_count = 1
    path_pattern  = "/manager/*"
  }
  customer-app = {
    image         = "bossnyumba/customer-app:staging"
    cpu           = 256
    memory        = 512
    port          = 3000
    desired_count = 1
    path_pattern  = "/app/*"
  }
  owner-portal = {
    image         = "bossnyumba/owner-portal:staging"
    cpu           = 256
    memory        = 512
    port          = 80
    desired_count = 1
    path_pattern  = "/owner/*"
  }
  admin-portal = {
    image         = "bossnyumba/admin-portal:staging"
    cpu           = 256
    memory        = 512
    port          = 80
    desired_count = 1
    path_pattern  = "/admin/*"
  }
}
