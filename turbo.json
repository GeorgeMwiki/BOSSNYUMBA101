{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "pipeline": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^build"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ]
    },
    "clean": {
      "cache": false
    }
  },
  "globalEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "JWT_SECRET",
    "JWT_REFRESH_SECRET",
    "JWT_EXPIRES_IN",
    "CLERK_SECRET_KEY",
    "MPESA_CONSUMER_KEY",
    "MPESA_CONSUMER_SECRET",
    "MPESA_PASSKEY",
    "MPESA_SHORTCODE",
    "MPESA_CALLBACK_SECRET",
    "MPESA_STK_RATE_LIMIT",
    "MPESA_STK_RATE_WINDOW_MS",
    "MPESA_STORE_BACKEND",
    "STRIPE_SECRET_KEY",
    "FLUTTERWAVE_SECRET_KEY",
    "AFRICAS_TALKING_API_KEY",
    "AFRICAS_TALKING_USERNAME",
    "SENDGRID_API_KEY",
    "FIREBASE_PROJECT_ID",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "AWS_S3_BUCKET",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "DEEPSEEK_API_KEY",
    "DEEPSEEK_ENABLED",
    "AI_PROVIDER",
    "TRA_API_URL",
    "TRA_USERNAME",
    "TRA_PASSWORD",
    "TRA_TIN",
    "KRA_ETIMS_API_URL",
    "KRA_ETIMS_PIN",
    "KRA_ETIMS_BHFID",
    "KRA_ETIMS_CMCKEY",
    "KRA_ERITS_API_URL",
    "KRA_ERITS_USERNAME",
    "KRA_ERITS_PASSWORD",
    "RETENTION_CRON_SCHEDULE",
    "MRI_RATE_OVERRIDE",
    "API_URL",
    "FRONTEND_URL",
    "NODE_ENV",
    "NEXT_PUBLIC_SUPPORT_PHONE",
    "NEXT_PUBLIC_SUPPORT_WHATSAPP",
    "NEXT_PUBLIC_API_URL"
  ]
}